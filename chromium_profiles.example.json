{
  "version": 1,
  "paths": {
    "chromium_dir": "/absolute/path/to/chromium-or-chrome",
    "chromedriver_path": "/absolute/path/to/chromedriver",
    "user_data_root": "/absolute/path/to/legacy-shared-user-data",
    "user_data_profiles_root": "/absolute/path/to/UserDataSplited",
    "mirror_user_data_root": "/absolute/path/to/UserDataSplited/mirror_disk",
    "bookmarks_template_path": "/absolute/path/to/bookmarks_template.html",
    "fingerprint_zip_path": "/absolute/path/to/fingerprint-extension.zip"
  },
  "app": {
    "minimize_to_tray_on_close": true,
    "language": "en",
    "browser_engine": "official_playwright_mcp",
    "concurrency_mode": "per_profile_live",
    "window_bounds": {
      "x": -1,
      "y": -1,
      "width": 860,
      "height": 680
    }
  },
  "mcp": {
    "enabled": true,
    "transport": "streamable-http",
    "host": "127.0.0.1",
    "port": 28888,
    "worker_port": 28889,
    "path": "/mcp",
    "log_level": "info",
    "idle_timeout_seconds": 60,
    "headless": false,
    "start_minimized": true
  },
  "launch": {
    "new_window": true,
    "start_maximized": true,
    "window_size": "",
    "no_first_run": true,
    "no_default_browser_check": true,
    "disable_background_networking": true,
    "disable_default_apps": true,
    "disable_sync": true,
    "metrics_recording_only": true,
    "disable_client_side_phishing_detection": false,
    "disable_webrtc": false,
    "webrtc_ip_handling_policy": "",
    "force_webrtc_ip_handling_policy": false,
    "load_fingerprint_extension": true,
    "open_extensions_page": false,
    "check_url": "",
    "extra_args": []
  },
  "profiles": [
    {
      "profile_name": "Profile 1",
      "user_data_dir_name": "UserDataProfile1",
      "account": "account-label@example.com",
      "keepalive_enabled": false,
      "keepalive_sites": {
        "chatgpt": false,
        "gmail": false,
        "google": false,
        "github": false
      },
      "notes": "Example entry only. Remove before real use.",
      "last_launch_at": "",
      "last_keepalive_at": "",
      "last_keepalive_status": "never",
      "last_keepalive_message": "",
      "last_keepalive_details": {}
    }
  ],
  "keepalive": {
    "enabled_sites": {
      "chatgpt": true,
      "gmail": true,
      "google": true,
      "github": false
    },
    "schedule_time": "06:00",
    "headless": false,
    "page_timeout_seconds": 45,
    "between_profiles_seconds": 5,
    "settle_seconds": 3,
    "site_dwell_seconds": 6,
    "chatgpt_prompt": "",
    "chatgpt_conversation_hint": "",
    "google_query": "profile keepalive",
    "plugin_dirs": [],
    "last_run_at": "",
    "last_run_finished_at": "",
    "last_run_status": "never",
    "last_run_message": "",
    "last_run_source": "",
    "last_run_profile_count": 0,
    "last_run_details": [],
    "last_scheduled_run_date": ""
  },
  "mirror": {
    "enabled": true,
    "disk_dir_name": "mirror_disk",
    "runtime_dir_name": "runtime",
    "cleanup_on_session_close": true,
    "max_runtime_age_hours": 24,
    "last_run_at": "",
    "last_run_finished_at": "",
    "last_run_status": "never",
    "last_run_message": "",
    "last_run_profile_count": 0
  }
}
